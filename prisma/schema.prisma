generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id Int  @id @default(autoincrement())
  email String @unique
  password String
  username String @unique
  avatarUrl String?
  links Link[]
}

model Link {
  id Int  @id @default(autoincrement())
  name String
  url String
  logoUrl String
  userId Int 
  user User @relation(fields: [userId], references: [id])

}